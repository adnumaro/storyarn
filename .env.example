# Storyarn Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection URL (required in production)
DATABASE_URL=ecto://postgres:postgres@localhost/storyarn_dev

MIX_TEST_PORT=4002

# Connection pool size
POOL_SIZE=10

# Enable IPv6 for database connections
# ECTO_IPV6=true

# =============================================================================
# PHOENIX / SECRETS
# =============================================================================
# Secret key base for signing cookies (required in production)
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Cloak encryption key for sensitive database fields (required in production)
# Generate with:
# elixir -e '32 |> :crypto.strong_rand_bytes() |> Base.encode64() |> IO.puts()'
CLOAK_KEY=

# Host for URL generation (required in production)
PHX_HOST=localhost

# Port for the web server
PORT=4000

# Enable the Phoenix server (for releases)
# PHX_SERVER=true

# Staging hardening
# NOINDEX=true serves robots.txt with Disallow: /. Staging response noindex
# headers are configured in fly.toml.
# NOINDEX=true

# =============================================================================
# REDIS (for PubSub and caching)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# EMAIL (Resend - https://resend.com)
# =============================================================================
# Required in production. Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# Required in production. Default sender must be verified in Resend.
MAILER_FROM_EMAIL=noreply@yourdomain.com
MAILER_FROM_NAME=Storyarn

ADMIN_EMAIL=
CONTACT_EMAIL=hello@storyarn.com

# =============================================================================
# STORAGE (required in production - Fly Tigris / S3-compatible)
# =============================================================================
# Production must use persistent object storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
AWS_ENDPOINT_URL_S3=

# Optional legacy/custom base URL. Buckets should remain private; browser media
# is delivered through authenticated Storyarn routes.
AWS_PUBLIC_URL=

# =============================================================================
# ANALYTICS AND ERROR TRACKING (optional)
# =============================================================================
# PostHog product analytics and optional error tracking
POSTHOG_ENABLED=false
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_FRONTEND_ENABLED=true
POSTHOG_ERROR_TRACKING_ENABLED=true
POSTHOG_FRONTEND_ERROR_TRACKING_ENABLED=true

# DNS cluster query for distributed Erlang
# DNS_CLUSTER_QUERY=

# =============================================================================
# VERSION CONTROL SAFETY SWITCHES
# =============================================================================
# Fail-closed kill switches. Leave disabled until each destructive surface has
# passed its referential-integrity audit.
SHEET_VERSION_RESTORE_ENABLED=false
FLOW_VERSION_RESTORE_ENABLED=false
SCENE_VERSION_RESTORE_ENABLED=false
PROJECT_SNAPSHOT_RESTORE_ENABLED=false
DELETED_PROJECT_RECOVERY_ENABLED=false
DELETED_PROJECT_SNAPSHOT_RETENTION_ENABLED=false
ENTITY_TRASH_RETENTION_ENABLED=false
AUTO_SNAPSHOT_PRUNING_ENABLED=false

# =============================================================================
# STORYARN AI MANAGED BETA (optional, disabled by default)
# =============================================================================
# Exactly one provider is active for new operations. Fireworks is the primary
# choice; Together remains an explicit alternative. There is no automatic
# provider fallback.
STORYARN_AI_MANAGED_ENABLED=false
STORYARN_AI_MANAGED_PROVIDER=fireworks

# Required operator attestations when managed AI is enabled.
STORYARN_AI_MANAGED_ZDR_VERIFIED=false
STORYARN_AI_MANAGED_NO_TRAINING_VERIFIED=false

# Only the selected provider key is required. Keep the previous provider key
# during a switch if already-queued operations should finish on that provider.
STORYARN_AI_FIREWORKS_API_KEY=
STORYARN_AI_TOGETHER_API_KEY=

# Optional provider-specific endpoint overrides. Defaults point to the official
# serverless Chat Completions endpoints.
# STORYARN_AI_FIREWORKS_ENDPOINT=https://api.fireworks.ai/inference/v1/chat/completions
# STORYARN_AI_TOGETHER_ENDPOINT=https://api.together.xyz/v1/chat/completions

# Required model and user-facing processing-location label for the active route.
STORYARN_AI_MANAGED_MODEL=
STORYARN_AI_MANAGED_REGION=global

# Immutable active-provider price snapshot and hard cost ceilings.
STORYARN_AI_PROVIDER_PRICE_VERSION=1
STORYARN_AI_PROVIDER_PRICE_CURRENCY=USD
STORYARN_AI_PROVIDER_INPUT_PER_MILLION=
STORYARN_AI_PROVIDER_OUTPUT_PER_MILLION=
STORYARN_AI_PROVIDER_MAX_OPERATION_COST=
STORYARN_AI_PROVIDER_GLOBAL_DAILY_CAP=
STORYARN_AI_PROVIDER_GLOBAL_MONTHLY_CAP=
STORYARN_AI_PROVIDER_WORKSPACE_DAILY_CAP=

# Internal promotional allowance price for the operator diagnostic.
STORYARN_AI_DIAGNOSTIC_PRICE_ID=managed-diagnostic-v1
STORYARN_AI_DIAGNOSTIC_PRICE_VERSION=1
STORYARN_AI_DIAGNOSTIC_PRICE_UNITS=1
