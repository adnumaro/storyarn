# Storyarn Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection URL (required in production)
DATABASE_URL=ecto://postgres:postgres@localhost/storyarn_dev

MIX_TEST_PORT=4002

# Connection pool size
POOL_SIZE=10

# Enable IPv6 for database connections
# ECTO_IPV6=true

# =============================================================================
# PHOENIX / SECRETS
# =============================================================================
# Secret key base for signing cookies (required in production)
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=

# Cloak encryption key for sensitive database fields (required in production)
# Generate with:
# elixir -e '32 |> :crypto.strong_rand_bytes() |> Base.encode64() |> IO.puts()'
CLOAK_KEY=

# Host for URL generation (required in production)
PHX_HOST=localhost

# Port for the web server
PORT=4000

# Enable the Phoenix server (for releases)
# PHX_SERVER=true

# Staging hardening
# NOINDEX=true serves robots.txt with Disallow: /. Staging response noindex
# headers are configured in fly.toml.
# NOINDEX=true

# =============================================================================
# REDIS (for PubSub and caching)
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# EMAIL (Resend - https://resend.com)
# =============================================================================
# Required in production. Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# Required in production. Default sender must be verified in Resend.
MAILER_FROM_EMAIL=noreply@yourdomain.com
MAILER_FROM_NAME=Storyarn

ADMIN_EMAIL=
CONTACT_EMAIL=hello@storyarn.com

# =============================================================================
# STORAGE (required in production - Fly Tigris / S3-compatible)
# =============================================================================
# Production must use persistent object storage.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
AWS_ENDPOINT_URL_S3=

# Optional legacy/custom base URL. Buckets should remain private; browser media
# is delivered through authenticated Storyarn routes.
AWS_PUBLIC_URL=

# =============================================================================
# ANALYTICS AND ERROR TRACKING (optional)
# =============================================================================
# PostHog product analytics and optional error tracking
POSTHOG_ENABLED=false
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_FRONTEND_ENABLED=true
POSTHOG_ERROR_TRACKING_ENABLED=true
POSTHOG_FRONTEND_ERROR_TRACKING_ENABLED=true

# DNS cluster query for distributed Erlang
# DNS_CLUSTER_QUERY=

# =============================================================================
# VERSION CONTROL SAFETY SWITCHES
# =============================================================================
# Fail-closed kill switches. Leave disabled until each destructive surface has
# passed its referential-integrity audit.
SHEET_VERSION_RESTORE_ENABLED=false
FLOW_VERSION_RESTORE_ENABLED=false
SCENE_VERSION_RESTORE_ENABLED=false
PROJECT_SNAPSHOT_RESTORE_ENABLED=false
DELETED_PROJECT_RECOVERY_ENABLED=false
DELETED_PROJECT_SNAPSHOT_RETENTION_ENABLED=false
ENTITY_TRASH_RETENTION_ENABLED=false
AUTO_SNAPSHOT_PRUNING_ENABLED=false
