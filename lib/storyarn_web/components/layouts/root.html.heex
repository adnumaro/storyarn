<!DOCTYPE html>
<html lang={assigns[:locale] || "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      :if={Application.get_env(:storyarn, :noindex, false)}
      name="robots"
      content="noindex, nofollow"
    />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      :if={Application.get_env(:sentry, :dsn)}
      name="sentry-dsn"
      content={Application.get_env(:sentry, :dsn)}
    />
    <link rel="icon" href={~p"/images/logos/logo-black-32.png"} type="image/png" sizes="32x32" />
    <link rel="icon" href={~p"/images/logos/logo-black-16.png"} type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href={~p"/images/logos/logo-black-180.png"} sizes="180x180" />
    <.live_title default="Storyarn" suffix=" · Storyarn">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script
      :if={assigns[:landing_page]}
      defer
      phx-track-static
      type="text/javascript"
      src={~p"/assets/js/landing.js"}
    >
    </script>
  </head>
  <body class="bg-base-100 antialiased">
    <div
      id="page-loader"
      class="fixed inset-0 z-[9999] flex items-center justify-center bg-base-200 hidden"
      style="will-change: transform; contain: strict"
    >
      <div
        class="animate-spin size-10 rounded-full border-4 border-primary border-t-transparent"
        style="will-change: transform"
      >
      </div>
    </div>
    {@inner_content}
  </body>
</html>
