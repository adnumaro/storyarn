<!DOCTYPE html>
<html lang={assigns[:locale] || "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="description" content={seo_description(assigns)} />
    <link rel="canonical" href={seo_canonical_url(assigns)} />
    <meta property="og:site_name" content="Storyarn" />
    <meta property="og:type" content={seo_type(assigns)} />
    <meta property="og:title" content={seo_title(assigns)} />
    <meta property="og:description" content={seo_description(assigns)} />
    <meta property="og:url" content={seo_canonical_url(assigns)} />
    <meta property="og:image" content={seo_image_url(assigns)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo_title(assigns)} />
    <meta name="twitter:description" content={seo_description(assigns)} />
    <meta name="twitter:image" content={seo_image_url(assigns)} />
    <%= if Application.get_env(:storyarn, :noindex, false) do %>
      <meta name="robots" content="noindex, nofollow" />
    <% end %>
    <%= if posthog = posthog_frontend_config(assigns) do %>
      <meta name="posthog-enabled" content="true" />
      <meta name="posthog-key" content={posthog.api_key} />
      <meta name="posthog-host" content={posthog.host} />
      <meta
        name="posthog-error-tracking-enabled"
        content={to_string(posthog.error_tracking_enabled)}
      />
      <%= if posthog.distinct_id do %>
        <meta name="posthog-user-id" content={posthog.distinct_id} />
      <% end %>
      <%= if posthog.user_locale do %>
        <meta name="posthog-user-locale" content={posthog.user_locale} />
      <% end %>
      <%= if is_boolean(posthog.user_super_admin) do %>
        <meta name="posthog-user-super-admin" content={to_string(posthog.user_super_admin)} />
      <% end %>
    <% end %>
    <link rel="icon" href={~p"/favicon.ico"} sizes="any" />
    <link rel="icon" href={~p"/images/logos/logo-black-32.png"} type="image/png" sizes="32x32" />
    <link rel="icon" href={~p"/images/logos/logo-black-48.png"} type="image/png" sizes="48x48" />
    <link rel="icon" href={~p"/images/logos/logo-black-192.png"} type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href={~p"/images/logos/logo-black-180.png"} sizes="180x180" />
    <link rel="manifest" href={~p"/site.webmanifest"} />
    <meta name="theme-color" content="#020617" />
    <.live_title default="Storyarn" suffix=" · Storyarn">
      {assigns[:page_title]}
    </.live_title>
    <PhoenixVite.Components.assets
      names={["assets/js/app.js", "assets/css/app.css"]}
      manifest={{:storyarn, "priv/static/.vite/manifest.json"}}
      dev_server={PhoenixVite.Components.has_vite_watcher?(StoryarnWeb.Endpoint)}
      to_url={
        fn path ->
          if PhoenixVite.Components.has_vite_watcher?(StoryarnWeb.Endpoint) do
            static_url(assigns[:conn] || assigns[:socket], path)
          else
            path
          end
        end
      }
    />
  </head>
  <body class="bg-background text-foreground antialiased">
    {@inner_content}
  </body>
</html>
