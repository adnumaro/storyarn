<!DOCTYPE html>
<html lang={assigns[:locale] || "en"}>
  <head>
    <script>
      // Sync theme class with localStorage (same key as v1: "phx:theme")
      (function() {
        var stored = localStorage.getItem("phx:theme");
        var dark = stored ? stored === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (dark) document.documentElement.classList.add("dark");
        else document.documentElement.classList.remove("dark");
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" href={~p"/images/logos/logo-white-32.png"} type="image/png" sizes="32x32" />
    <.live_title default="Storyarn" suffix=" · Storyarn">
      {assigns[:page_title]}
    </.live_title>
    <PhoenixVite.Components.assets
      names={["js/app.js", "css/app.css"]}
      manifest={{:storyarn, "priv/static/.vite/manifest.json"}}
      dev_server={PhoenixVite.Components.has_vite_watcher?(StoryarnWeb.Endpoint)}
      to_url={fn p -> static_url(assigns[:conn] || assigns[:socket], p) end}
    />
  </head>
  <body class="bg-background text-foreground antialiased">
    {@inner_content}
  </body>
</html>
