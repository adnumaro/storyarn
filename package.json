{
  "name": "storyarn-assets",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "node_modules/.bin/oxlint",
    "lint:fix": "node_modules/.bin/oxlint --fix",
    "fmt": "node_modules/.bin/oxfmt",
    "fmt:check": "node_modules/.bin/oxfmt --check",
    "arch": "npm run arch:deps && npm run arch:live-vue && npm run arch:links && npm run arch:sessions",
