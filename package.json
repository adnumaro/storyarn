    "arch:live-vue": "node scripts/verify-live-vue-components.mjs",
    "arch:links": "node scripts/verify-live-links.mjs",
    "arch:sessions": "node scripts/verify-live-sessions.mjs",
    "build:grammar": "node_modules/.bin/lezer-generator assets/app/plugins/expression-editor/storyarn-expr.grammar -o assets/app/plugins/expression-editor/parser-generated.js",
    "test": "node_modules/.bin/vitest run",
    "test:watch": "node_modules/.bin/vitest",
    "knip": "knip"
  },
