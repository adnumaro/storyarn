{
  "compilerOptions": {
    "baseUrl": "./assets",
    "paths": {
      "*": ["../deps/*"],
      "@app/*": ["./app/*"],
      "@components/*": ["./app/components/*"],
      "@lib/*": ["./app/lib/*"],
      "@pages/*": ["./app/pages/*"],
      "@composables/*": ["./app/composables/*"]
    },
    "allowJs": true,
    "noEmit": true
  },
  "include": ["js/**/*", "app/**/*"]
}
